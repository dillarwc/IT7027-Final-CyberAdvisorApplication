<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CyberAdvisorApplication.Pages.SettingsPg"
             Title="Settings">

    <VerticalStackLayout Padding="20" Spacing="20">
        <Label Text="Settings"
         FontSize="24"  FontAttributes="Bold" />

        <Label Text="Theme Options"  FontSize="24"  FontAttributes="Bold" />

        <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
            <Button Grid.Column="0" Text="Default" Clicked="BtnDefault_Clicked" CornerRadius="20" />

            <Button Grid.Column="1" Text="Dark"  TextColor="White" Clicked="BtnDark_Clicked" CornerRadius="20" Background="DimGray"/>
        </Grid>
    </VerticalStackLayout>
</ContentPage>