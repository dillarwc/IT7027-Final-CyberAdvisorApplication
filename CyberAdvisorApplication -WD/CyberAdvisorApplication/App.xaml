<?xml version = "1.0" encoding = "UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:CyberAdvisorApplication"
             x:Class="CyberAdvisorApplication.App">
    <Application.Resources>
        <ResourceDictionary>
            
            
            
            <Style TargetType="ContentPage">
                <Setter Property="BackgroundColor"
                        Value="{AppThemeBinding Light=White, Dark=Black}" />
            </Style>

            <Style TargetType="Label">
                <Setter Property="TextColor"
                        Value="{AppThemeBinding Light=Black, Dark=White}" />
            </Style>



            <Style TargetType="Button">
                <Setter Property="TextColor"
                        Value="{AppThemeBinding Light=Black, Dark=White}" />
                <Setter Property="BackgroundColor"
                        Value="{AppThemeBinding Light=#E0E0E0, Dark=Red}" />
            </Style>
            <!--<Style TargetType="CollectionView">
                <Setter Property="TextColor"
                        Value="{AppThemeBinding Light=Black, Dark=White}" />
                <Setter Property="BackgroundColor"
                        Value="{AppThemeBinding Light=White, Dark=#3A3A3A}" />
            </Style>-->
            <Style TargetType="CollectionView">
                <Setter Property="BackgroundColor"
                        Value="{AppThemeBinding Light=White, Dark=#3A3A3A}" />
               
                
            </Style>

            <Style TargetType="Frame">
                <Setter Property="BackgroundColor"
                        Value="{AppThemeBinding Light=White, Dark=#3A3A3A}" />
                <Setter Property="BorderColor"
                        Value="{AppThemeBinding Light=Black, Dark=White}" />
            </Style>



        </ResourceDictionary>
    </Application.Resources>
</Application>
